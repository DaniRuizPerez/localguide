{
  "expo": {
    "name": "Local Guide App",
    "slug": "local-guide-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.localguideapp",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Local Guide uses your location to provide information about nearby landmarks and points of interest.",
        "NSLocationAlwaysUsageDescription": "Local Guide uses your location to provide information about nearby landmarks and points of interest."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.localguideapp",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION", "INTERNET"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
